# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive (service account — shared org Drive)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Transcription (AssemblyAI default)
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=

# WebAuthn
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Scribe
WEBAUTHN_ORIGIN=http://localhost:3000

# Vonage (SMS OTP login)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_BRAND_NAME=Scribe
# Set after running scripts/setup-vonage-webotp-template.mjs once — enables
# WebOTP auto-fill of the code on Android Chrome. Optional, login works
# without it, just without auto-fill.
VONAGE_SMS_TEMPLATE_ID=
