# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Drive (service account — shared org Drive)
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_FOLDER_ID=

# Transcription (AssemblyAI default)
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=

# WebAuthn
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Scribe
WEBAUTHN_ORIGIN=http://localhost:3000

# Vonage (SMS OTP login)
# Verify v2 authenticates with a JWT signed by a Vonage Application's private
# key (the @vonage/verify2 client is JWT-only), so the APPLICATION_ID +
# PRIVATE_KEY below are REQUIRED at runtime for login to work. API key/secret
# is only a fallback and won't authenticate Verify v2 on its own.
VONAGE_LIGA_SCRIBE_APPLICATION_ID=
VONAGE_PRIVATE_KEY=
VONAGE_BRAND_NAME=Scribe
# Sender shown on the OTP text. A Vonage virtual number, or an alphanumeric
# sender ID (e.g. "Scribe") where the destination country allows it (Czech
# does). Falls back to VONAGE_BRAND_NAME if unset.
VONAGE_SMS_FROM=
# Account API key/secret — get these from dashboard.vonage.com/applications.
# Not sufficient for Verify v2 alone; kept as a fallback.
VONAGE_API_KEY=
VONAGE_API_SECRET=
# Set after running scripts/setup-vonage-webotp-template.mjs once — enables
# WebOTP auto-fill of the code on Android Chrome. Optional, login works
# without it, just without auto-fill.
VONAGE_SMS_TEMPLATE_ID=

# Alerting (nikpage/app-hub's notify-hub Worker -> Slack). Optional: if unset,
# src/lib/notify.ts silently no-ops (e.g. local dev). Get the token from
# app-hub's scripts/seed-scribe.sh.
NOTIFY_HUB_TOKEN=
NOTIFY_HUB_URL=https://notify-hub.ainikpage.workers.dev/notify
